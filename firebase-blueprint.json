{
  "entities": {
    "TournamentData": {
      "title": "TournamentData",
      "description": "The current state of the global tournament.",
      "type": "object",
      "properties": {
        "teams": { "type": "array" },
        "preSeason": { "type": "object" },
        "novaCup": { "type": "object" },
        "superNovaCup": { "type": "object" }
      },
      "required": ["teams", "preSeason", "novaCup", "superNovaCup"]
    }
  },
  "firestore": {
    "/tournament/{docId}": {
      "schema": "TournamentData",
      "description": "Global tournament singleton document."
    }
  }
}
