{
  "entities": {
    "Tournament": {
      "title": "Tournament Data",
      "description": "Stores the entire state of the DOTA 2 tournament",
      "type": "object",
      "properties": {
        "teams": { "type": "array" },
        "preSeason": { "type": "object" },
        "novaCup": { "type": "object" },
        "superNovaCup": { "type": "object" }
      },
      "required": ["teams", "preSeason", "novaCup", "superNovaCup"]
    }
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": { "$ref": "#/entities/Tournament" },
      "description": "Store tournament data"
    }
  }
}
